import requests
from concurrent.futures import ThreadPoolExecutor

input_file = "google-subdomain-list.txt"
output_file = "result.txt"

up_list = []
down_list = []

def check_domain(domain):
    try:
        url = f"http://{domain}"
        r = requests.get(url, timeout=3)
        if r.status_code < 500:
            return (domain, "UP")
        else:
            return (domain, "DOWN")
    except:
        return (domain, "DOWN")

with open(input_file, "r") as f:
    domains = [line.strip() for line in f if line.strip()]

# 🔥 Threading (speed boost)
with ThreadPoolExecutor(max_workers=50) as executor:
    results = executor.map(check_domain, domains)

for domain, status in results:
    print(f"{domain} --> {status}")
    if status == "UP":
        up_list.append(domain)
    else:
        down_list.append(domain)

with open(output_file, "w") as f:
    f.write("====== UP DOMAINS ======\n")
    for u in up_list:
        f.write(u + "\n")

    f.write("\n====== DOWN DOMAINS ======\n")
    for d in down_list:
        f.write(d + "\n")

print("\n🔥 Done! Fast scan completed. Saved in result.txt")
